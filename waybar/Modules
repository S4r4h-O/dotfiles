{
  // check /sys/class/hwmon to list your devices
  "temperature": {
    "interval": 10,
    "tooltip": true,
    "hwmon-path": ["/sys/class/hwmon/hwmon4/temp1_input"],
    "critical-threshold": 82,
    "format": "Temp {icon} {temperatureC}┬░C",
    "format-icons": ["≤░Ι╕"],
    "on-click-right": "alacritty --title nvtop -e nvtop"
  },

  "backlight": {
    "interval": 2,
    "format": "{icon}",
    "format-icons": ["ΌΠΧ", "ΌΠΩ", "ΌΠγ", "≤░Δζ", "≤░Δη", "≤░Δθ", "≤░Δι"],
    "tooltip-format": "backlight {percent}%",
    "on-scroll-up": "$HOME/.config/niri/scripts/brightness.sh --inc",
    "on-scroll-down": "$HOME/.config/niri/scripts/brightness.sh --dec",
    "smooth-scrolling-threshold": 1
  },

  "backlight#2": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["ΎΗΖ", "ΎΕΣ"]
  },

  "battery": {
    "full-at": 100,
    "design-capacity": false,
    "states": { "good": 95, "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-plugged": "≤▒αΨ {capacity}%",
    "format-full": "{icon} Full",
    "format-alt": "{icon} {time}",
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    "format-time": "{H}h {M}min",
    "tooltip": true,
    "tooltip-format": "{timeTo} {power}w"
  },

  "bluetooth": {
    "format": "ΎΛΥ ",
    "format-disabled": "≤░Γ│",
    "format-connected": "≤░Γ▒ {num_connections}",
    "tooltip-format": "ΎΛΥ {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "ΎΛΥ {device_alias} ≤░ΓΕ{device_battery_percentage}%",
    "tooltip": true,
    "on-click": "blueman-manager"
  },

  "clock": {
    "interval": 1,
    "format": "{:%A %d.%m.%Y - %H:%M}",
    "format-alt": "ΎΑΩ {:%H:%M  ΎΒ│ %Y, %d %B, %A}",
    "tooltip": false,
    "on-click-right": "gsimplecal"
  },

  "cpu": {
    "interval": 1,
    "format": "Cpu ≤░Ξδ {usage}%",
    "format-alt": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% ≤░Ξδ",
    "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
    "on-click-right": "alacritty --title btop -e btop"
  },

  "disk": {
    "interval": 30,
    "path": "/",
    "format": "Disk ≤░ΜΛ {used}",
    "tooltip-format": "{used} used out of {total} on {path} ({percentage_used}%)",
    "on-click-right": "thunar"
  },

  "memory": {
    "interval": 10,
    "format": "Ram ≤░╛Η {used:0.1f}G",
    "format-alt": "{percentage}% ≤░╛Η",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
    "on-click-right": "alacritty -e btop"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} ≤░Γ░ {volume}%",
    "format-muted": "≤░ΨΒ",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΑξ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "≤░Χ╛", "ΎΑρ"]
    },
    "scroll-step": 5,
    "on-click": "pavucontrol -t 3",
    "on-click-right": "$HOME/.config/niri/scripts/volume.sh --toggle",
    "on-scroll-up": "$HOME/.config/niri/scripts/volume.sh --inc",
    "on-scroll-down": "$HOME/.config/niri/scripts/volume.sh --dec",
    "smooth-scrolling-threshold": 1
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "on-click": "$HOME/.config/niri/scripts/volume.sh --toggle-mic",
    "on-click-right": "pavucontrol -t 4",
    "on-scroll-up": "$HOME/.config/niri/scripts/volume.sh --mic-inc",
    "on-scroll-down": "$HOME/.config/niri/scripts/volume.sh --mic-dec"
  },

  "network": {
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-ethernet": "≤░Να",
    "format-disconnected": "≤░Νβ",
    "tooltip-format": "{ipaddr} ΎΕ╣ {bandwidthUpBits} ΎΕ║ {bandwidthDownBits}",
    "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"]
  },

  "tray": {
    "icon-size": 20,
    "spacing": 4,
    "show-passive-items": true
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": { "activated": "ΎΒχ ", "deactivated": "ΎΒ░ " }
  },

  "mpris": {
    "format": "{player_icon} {title} - {artist}",
    "format-paused": "έΠ╕ {title} - {artist}",
    "format-stopped": "Όχξ",
    "player-icons": {
      "default": "έΨ╢",
      "spotify": "ΎΗ╝",
      "firefox": "≤░Ι╣",
      "chromium": "≤░Λψ"
    },
    "interval": 2,
    "max-length": 40,
    "tooltip": true,
    "tooltip-format": "{title} / {artist} / {album}"
  },

  "custom/power": {
    "format": "έΠ╗",
    "tooltip": false,
    "on-click": "wlogout"
  }
}

