" ============================================================================
" .ideavimrc — LazyVim parity
" IdeaVim 2.30.0 / IntelliJ IDEA 2025.3.3 (Linux)
"
" REQUIRES (Marketplace — install before sourcing):
"   Which-Key       https://plugins.jetbrains.com/plugin/15976-which-key
"   IdeaVim-EasyMotion  https://plugins.jetbrains.com/plugin/13360-ideavim-easymotion
"   AceJump         https://plugins.jetbrains.com/plugin/7086-acejump
"   Vim Dial        https://plugins.jetbrains.com/plugin/28237-vim-dial
"   org.yelog.ideavim.flash — s/S jump labels activate automatically.
"   Configure via: Settings -> Other Settings -> vim-flash
" ============================================================================


" ============================================================================
" PLUGINS
" Built-in IdeaVim emulations: use `set`.
" Marketplace-backed: use `Plug` (requires the JetBrains plugin to be installed).
" ============================================================================
set surround
set commentary
set ReplaceWithRegister
set exchange
set textobj-indent
set argtextobj
set textobj-entire
set highlightedyank
set NERDTree
set multiple-cursors
set vim-paragraph-motion
set mini-ai
set matchit
set dial
set which-key
set multicursor

Plug 'easymotion/vim-easymotion'

" vim-flash (org.yelog.ideavim.flash) is a JetBrains plugin, not an IdeaVim
" emulation. No Plug declaration needed. Binds s/S automatically.
" Map flash.remote to r in operator-pending mode (flash.nvim 'r' parity):
omap r <Action>(flash.remote)
map s <Action>(flash.search)
map S <Action>(flash.search)
omap r <Action>(flash.remote)


" ============================================================================
" OPTIONS
" ============================================================================
set scrolloff=8
set sidescrolloff=8
set number
set relativenumber
set ignorecase
set smartcase
set incsearch
set hlsearch
set history=10000
set showcmd
set showmode
set notimeout
" set timeoutlen=5000

" IDE integration
set ideajoin
set idearefactormode=select
set ideamarks
set ideawrite=all
set ideastatusicon=enabled

" Clipboard — ideaput enables IDE paste with automatic import insertion
set clipboard+=unnamed
set clipboard+=unnamedplus
set clipboard+=ideaput

" highlightedyank duration (ms)
let g:highlightedyank_highlight_duration = "300"

" argtextobj — extend to all bracket types (matches mini.ai scope)
let g:argtextobj_pairs="(:),{:},[:],<:>"

" EasyMotion — disable auto-mappings; defined explicitly below
let g:EasyMotion_do_mapping = 0
let g:EasyMotion_smartcase = 1


" ============================================================================
" LEADER
" ============================================================================
let mapleader = " "


" ============================================================================
